{
  "name": "charles-portfolio",
  "version": "1.0.0",
  "private": true,
  "description": "Professional portfolio website built with Next.js 15, React 19, TypeScript, and Prisma",
  "author": "Charles Kwakye",
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "test": "dotenv -e .env.test.local -- vitest run",
    "test:watch": "dotenv -e .env.test.local -- vitest",
    "test:coverage": "dotenv -e .env.test.local -- vitest run --coverage",
    "test:ui": "dotenv -e .env.test.local -- vitest --ui",
    "test:api": "dotenv -e .env.test.local -- vitest run src/__tests__/api",
    "test:db": "dotenv -e .env.test.local -- vitest run src/__tests__/integration",
    "test:all": "dotenv -e .env.test.local -- vitest run",
    "test:start-db": "dotenv -e .env.test.local -- docker-compose -f docker-compose.test.yml up -d",
    "test:stop-db": "docker-compose -f docker-compose.test.yml down",
    "test:clean": "docker-compose -f docker-compose.test.yml down -v && dotenv -e .env.test.local -- docker-compose -f docker-compose.test.yml up -d",
    "postinstall": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "db:seed": "npx ts-node prisma/seed.ts",
    "db:seed:prod": "npx ts-node prisma/seed-recovered-data.ts",
    "db:reset": "prisma migrate reset --force",
    "db:setup:test": "createdb portfolio_test || true"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@hookform/resolvers": "^4.1.3",
    "@prisma/client": "^6.6.0",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@types/uuid": "^10.0.0",
    "@vercel/blob": "^0.27.3",
    "@vercel/postgres": "^0.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^5.6.0",
    "cuid": "^3.0.0",
    "date-fns": "^4.1.0",
    "lucide-react": "^0.482.0",
    "next": "15.4.10",
    "next-auth": "^4.24.13",
    "next-themes": "^0.4.6",
    "nodemailer": "^7.0.13",
    "prisma": "^6.6.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7.54.2",
    "react-hot-toast": "^2.5.2",
    "react-icons": "^5.5.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.1",
    "tailwind-merge": "^3.0.2",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^11.1.0",
    "winston": "^3.17.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@faker-js/faker": "^9.6.0",
    "@shadcn/ui": "^0.0.4",
    "@tailwindcss/forms": "^0.5.10",
    "@tailwindcss/typography": "^0.5.16",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/nodemailer": "^6.4.17",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/supertest": "^7.2.0",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "autoprefixer": "^10.4.21",
    "dotenv-cli": "^11.0.0",
    "eslint": "^9",
    "eslint-config-next": "15.2.2",
    "msw": "^2.12.7",
    "postcss": "^8.5.3",
    "supertest": "^7.2.2",
    "tailwindcss": "^3.4.17",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
