# Test environment configuration
# Uses LOCAL PostgreSQL - completely separate from production
# This ensures tests never touch production data

# Local PostgreSQL database for testing (default: postgres user)
# For macOS, you may need to set your username in .env.test.local
DATABASE_URL="postgresql://postgres@localhost:5432/portfolio_test"

# NextAuth configuration for testing
NEXTAUTH_SECRET="test-secret-key-for-testing-only"
NEXTAUTH_URL="http://localhost:3000"

# Admin credentials for authentication testing
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# Debug flag - set to 'true' to see database queries during tests
DEBUG_TESTS="false"

# Vercel Blob - tests will mock this
BLOB_READ_WRITE_TOKEN="test_blob_token_for_testing"
