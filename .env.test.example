# Local test environment template
# Copy this file to .env.test.local and fill in your values

# =====================================================
# LOCAL POSTGRESQL CONFIGURATION
# =====================================================
# For macOS, your username is typically what you get from the 'whoami' command
# The password depends on your local PostgreSQL setup (may be empty on some systems)

# Your local PostgreSQL username
POSTGRES_USER=your_mac_username

# Your local PostgreSQL password (may be empty if no password set)
POSTGRES_PASSWORD=your_password

# =====================================================
# DATABASE URL
# =====================================================
# IMPORTANT: The credentials in DATABASE_URL must match POSTGRES_USER and POSTGRES_PASSWORD above.
# This is because Docker uses the top variables, and the app uses DATABASE_URL.
# Use the SAME values as above (your_username:your_password)
DATABASE_URL="postgresql://your_username:your_password@localhost:5432/portfolio_test"

# =====================================================
# NEXTAUTH CONFIGURATION (can keep as-is)
# =====================================================
NEXTAUTH_SECRET="test-secret-key-for-testing-only"
NEXTAUTH_URL="http://localhost:3000"

# =====================================================
# ADMIN CREDENTIALS FOR TESTS (can keep as-is)
# =====================================================
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin123"

# =====================================================
# OTHER SETTINGS (can keep as-is)
# =====================================================
DEBUG_TESTS="false"
BLOB_READ_WRITE_TOKEN="test_blob_token_for_testing"
